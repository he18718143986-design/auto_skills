{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "./out",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "src/webview/runtime/**",
    "src/webview/sidebar/**",
    "src/webview/webview-main-entry.ts",
    "src/webview/webview-shared-entry.ts",
    "src/webview/decision-pause-bar-entry.tsx",
    "src/webview/stage-timeline-entry.tsx",
    "src/webview/components/**",
    "src/webview/l10n/**"
  ]
}
