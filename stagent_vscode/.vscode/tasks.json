{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "stagent: compile",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/scripts/compile-for-vscode.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "/opt/homebrew/bin:/usr/local/bin:${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "group": "build",
      "label": "npm: compile",
      "problemMatcher": ["$tsc"],
      "dependsOn": []
    }
  ]
}
