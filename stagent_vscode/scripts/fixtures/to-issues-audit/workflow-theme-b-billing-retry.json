{
  "id": "workflow_billing_retry_idempotency",
  "version": "2.0",
  "meta": {
    "title": "Billing Retry Idempotency",
    "taskType": "software",
    "userInput": "为账单扣费失败重试链路增加幂等保障与补偿日志，避免重复扣费。",
    "createdAt": "2026-05-09T14:46:30.000Z",
    "isGreenfield": false
  },
  "stages": [
    {
      "id": "stage_zoom_out",
      "title": "读取模块地图",
      "tool": "file-read",
      "toolConfig": {
        "type": "file-read",
        "filePath": "package.json"
      },
      "input": {
        "sources": [
          { "type": "user-input", "label": "需求" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "moduleMap", "format": "markdown" }
      ],
      "pauseAfter": false
    },
    {
      "id": "stage_decide_retry_guard",
      "title": "决策重试幂等守卫模块",
      "isDecisionStage": true,
      "tool": "llm-text",
      "toolConfig": {
        "type": "llm-text",
        "systemPrompt": "请产出 retry_guard 模块的决策清单，覆盖幂等键、冲突处理与回滚策略。"
      },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_zoom_out", "outputKey": "moduleMap", "label": "模块映射" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "decisionRecord", "format": "markdown" }
      ],
      "pauseAfter": true
    },
    {
      "id": "stage_test_write_retry_guard",
      "title": "编写重试幂等守卫测试",
      "tool": "llm-text",
      "toolConfig": {
        "type": "llm-text",
        "systemPrompt": "按主路径、补偿路径、边界冲突顺序输出 retry_guard 的测试。"
      },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_decide_retry_guard", "outputKey": "decisionRecord", "label": "决策清单" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "testPlan", "format": "markdown" }
      ],
      "pauseAfter": false
    },
    {
      "id": "stage_impl_retry_guard",
      "title": "实现重试幂等守卫",
      "tool": "llm-text",
      "toolConfig": {
        "type": "llm-text",
        "systemPrompt": "严格按照已确认的决策清单实现，不得偏离。如发现清单中存在矛盾，在代码注释中标注。"
      },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_decide_retry_guard", "outputKey": "decisionRecord", "label": "已确认的决策清单" },
          { "type": "stage-output", "stageId": "stage_test_write_retry_guard", "outputKey": "testPlan", "label": "测试计划" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "implPatch", "format": "markdown" }
      ],
      "pauseAfter": false
    },
    {
      "id": "stage_test_run_retry_guard",
      "title": "运行重试幂等守卫测试",
      "tool": "code-runner",
      "toolConfig": {
        "type": "code-runner",
        "command": "npm run test -- retry-guard",
        "captureOutput": true
      },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_impl_retry_guard", "outputKey": "implPatch", "label": "实现结果" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "testReport", "format": "markdown" }
      ],
      "pauseAfter": false
    }
  ]
}
