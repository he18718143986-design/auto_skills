    {
      "id": "stage_decide_rate_limit_guard",
      "title": "决策限流守卫模块",
      "isDecisionStage": true,
      "tool": "llm-text",
      "toolConfig": { "type": "llm-text", "systemPrompt": "产出限流守卫决策清单，覆盖令牌桶参数、降级策略、告警阈值。" },
      "input": {
        "sources": [{ "type": "stage-output", "stageId": "stage_zoom_out", "outputKey": "moduleMap", "label": "模块映射" }],
        "mergeStrategy": "concat"
      },
      "outputs": [{ "key": "decisionRecord", "format": "markdown" }],
      "pauseAfter": true
    },
    {
      "id": "stage_test_write_rate_limit_guard",
      "title": "编写限流守卫测试",
      "tool": "llm-text",
      "toolConfig": { "type": "llm-text", "systemPrompt": "按稳态、突发、回退路径输出 rate_limit_guard 测试。" },
      "input": {
        "sources": [{ "type": "stage-output", "stageId": "stage_decide_rate_limit_guard", "outputKey": "decisionRecord", "label": "决策清单" }],
        "mergeStrategy": "concat"
      },
      "outputs": [{ "key": "testPlan", "format": "markdown" }],
      "pauseAfter": false
    },
    {
      "id": "stage_impl_rate_limit_guard",
      "title": "实现限流守卫",
      "tool": "llm-text",
      "toolConfig": { "type": "llm-text", "systemPrompt": "严格按照已确认的决策清单实现，不得偏离。如发现清单中存在矛盾，在代码注释中标注。" },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_decide_rate_limit_guard", "outputKey": "decisionRecord", "label": "已确认的决策清单" },
          { "type": "stage-output", "stageId": "stage_test_write_rate_limit_guard", "outputKey": "testPlan", "label": "测试计划" }
