      "outputs": [{ "key": "implPatch", "format": "markdown" }],
      "pauseAfter": false
    },
    {
      "id": "stage_test_run_rate_limit_guard",
      "title": "运行限流守卫测试",
      "tool": "code-runner",
      "toolConfig": { "type": "code-runner", "command": "npm run test -- rate-limit-guard", "captureOutput": true },
      "input": {
        "sources": [{ "type": "stage-output", "stageId": "stage_impl_rate_limit_guard", "outputKey": "implPatch", "label": "实现结果" }],
        "mergeStrategy": "concat"
      },
      "outputs": [{ "key": "testReport", "format": "markdown" }],
      "pauseAfter": false
