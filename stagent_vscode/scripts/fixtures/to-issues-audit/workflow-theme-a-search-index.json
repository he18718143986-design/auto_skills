{
  "id": "workflow_search_index_refactor",
  "version": "2.0",
  "meta": {
    "title": "Search Index Incremental Refactor",
    "taskType": "software",
    "userInput": "将现有搜索索引重构为增量更新模式，避免全量重建，并保留现有查询接口兼容。",
    "createdAt": "2026-05-09T14:46:00.000Z",
    "isGreenfield": false
  },
  "stages": [
    {
      "id": "stage_zoom_out",
      "title": "读取模块地图",
      "tool": "file-read",
      "toolConfig": {
        "type": "file-read",
        "filePath": "package.json"
      },
      "input": {
        "sources": [
          { "type": "user-input", "label": "需求" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "moduleMap", "format": "markdown" }
      ],
      "pauseAfter": false
    },
    {
      "id": "stage_decide_index_updater",
      "title": "决策增量更新器模块",
      "isDecisionStage": true,
      "tool": "llm-text",
      "toolConfig": {
        "type": "llm-text",
        "systemPrompt": "请产出 index_updater 模块的决策清单，并说明为何不采用全量重建。"
      },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_zoom_out", "outputKey": "moduleMap", "label": "模块映射" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "decisionRecord", "format": "markdown" }
      ],
      "pauseAfter": true
    },
    {
      "id": "stage_test_write_index_updater",
      "title": "编写增量更新器测试",
      "tool": "llm-text",
      "toolConfig": {
        "type": "llm-text",
        "systemPrompt": "按关键路径优先编写 index_updater 的测试用例。"
      },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_decide_index_updater", "outputKey": "decisionRecord", "label": "决策清单" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "testPlan", "format": "markdown" }
      ],
      "pauseAfter": false
    },
    {
      "id": "stage_impl_index_updater",
      "title": "实现增量更新器",
      "tool": "llm-text",
      "toolConfig": {
        "type": "llm-text",
        "systemPrompt": "严格按照已确认的决策清单实现，不得偏离。如发现清单中存在矛盾，在代码注释中标注。"
      },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_decide_index_updater", "outputKey": "decisionRecord", "label": "已确认的决策清单" },
          { "type": "stage-output", "stageId": "stage_test_write_index_updater", "outputKey": "testPlan", "label": "测试计划" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "implPatch", "format": "markdown" }
      ],
      "pauseAfter": false
    },
    {
      "id": "stage_test_run_index_updater",
      "title": "运行增量更新器测试",
      "tool": "code-runner",
      "toolConfig": {
        "type": "code-runner",
        "command": "npm run test -- index-updater",
        "captureOutput": true
      },
      "input": {
        "sources": [
          { "type": "stage-output", "stageId": "stage_impl_index_updater", "outputKey": "implPatch", "label": "实现结果" }
        ],
        "mergeStrategy": "concat"
      },
      "outputs": [
        { "key": "testReport", "format": "markdown" }
      ],
      "pauseAfter": false
    }
  ]
}
