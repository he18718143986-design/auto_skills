{
  "name": "autoai",
  "version": "0.1.0",
  "description": "Connect to any AI — free, without API keys",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "build:core": "tsc -b packages/stagent-core",
    "predev": "npm run build:core",
    "prebuild": "npm run build:core",
    "pretypecheck": "npm run build:core",
    "pretest": "npm run build:core",
    "dev": "electron-vite dev",
    "dev:playwright": "AUTOAI_AUTOMATION_MODE=playwright electron-vite dev",
    "dev:playwright:chatgpt": "AUTOAI_PLAYWRIGHT_HOSTS=chatgpt.com electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "preview:playwright": "AUTOAI_AUTOMATION_MODE=playwright electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "npm run build && playwright test",
    "regression:loop": "node scripts/run-regression-loop.js",
    "extract:failure-snapshot": "node scripts/extract-failure-snapshot.js",
    "adapter:gates": "node scripts/check-adapter-gates.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@stagent/core": "file:./packages/stagent-core",
    "electron-log": "^5.4.3",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.378.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.5"
  }
}
